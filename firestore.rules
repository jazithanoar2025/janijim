rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/usuarios/$(uid);
    }

    function hasProfile() {
      return signedIn() && exists(userPath(request.auth.uid));
    }

    function profile() {
      return get(userPath(request.auth.uid)).data;
    }

    function isSuperadmin() {
      return hasProfile() && profile().rol == 'superadmin';
    }

    function isAdminFor(grupoId) {
      return hasProfile() && profile().rol == 'admin' && profile().grupoId == grupoId;
    }

    function ninoPath(ninoId) {
      return /databases/$(database)/documents/ninos/$(ninoId);
    }

    function canReadOrWriteNino(ninoId) {
      return isSuperadmin() || (exists(ninoPath(ninoId)) && isAdminFor(get(ninoPath(ninoId)).data.grupoId));
    }

    function isNonEmptyString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function isOptionalString(data, field, maxLength) {
      return !(field in data) || (data[field] is string && data[field].size() <= maxLength);
    }

    function isOptionalBool(data, field) {
      return !(field in data) || data[field] is bool;
    }

    function isOptionalRole(data, field) {
      return !(field in data) || data[field] in ['superadmin', 'admin'];
    }

    function isNonNegativeNumber(value) {
      return value is number && value >= 0 && value < 1000000;
    }

    function isIsoDate(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function validUsuario(data) {
      return data.keys().hasOnly(['email', 'nombre', 'rol', 'grupoId']) &&
        isNonEmptyString(data.email, 254) &&
        isNonEmptyString(data.nombre, 120) &&
        data.rol in ['superadmin', 'admin'] &&
        (
          (data.rol == 'superadmin' && data.grupoId == null) ||
          (data.rol == 'admin' && isNonEmptyString(data.grupoId, 128))
        );
    }

    function validGrupo(data) {
      return data.keys().hasOnly(['nombre', 'adminUid']) &&
        isNonEmptyString(data.nombre, 120) &&
        isOptionalString(data, 'adminUid', 128);
    }

    function validNino(data) {
      return data.keys().hasOnly(['nombre', 'apellido', 'grupoId', 'escuela', 'escuelaId', 'telefono', 'observaciones', 'activo', 'creadoEn', 'creadoPor', 'creadoPorRol']) &&
        isNonEmptyString(data.nombre, 80) &&
        isNonEmptyString(data.apellido, 80) &&
        isNonEmptyString(data.grupoId, 128) &&
        isOptionalString(data, 'escuela', 120) &&
        isOptionalString(data, 'escuelaId', 180) &&
        isOptionalString(data, 'telefono', 40) &&
        isOptionalString(data, 'observaciones', 500) &&
        isOptionalString(data, 'creadoEn', 40) &&
        isOptionalString(data, 'creadoPor', 254) &&
        isOptionalRole(data, 'creadoPorRol') &&
        isOptionalBool(data, 'activo');
    }

    function validSabado(data) {
      return data.keys().hasOnly(['fecha', 'monto', 'observacion', 'creadoEn', 'creadoPor']) &&
        isIsoDate(data.fecha) &&
        isNonNegativeNumber(data.monto) &&
        isOptionalString(data, 'observacion', 500) &&
        isOptionalString(data, 'creadoEn', 40) &&
        isOptionalString(data, 'creadoPor', 254);
    }

    function validRegistro(data) {
      return data.keys().hasOnly(['ninoId', 'sabadoId', 'vino', 'pago', 'fechaHora', 'registradoPor']) &&
        isNonEmptyString(data.ninoId, 128) &&
        isNonEmptyString(data.sabadoId, 128) &&
        data.vino is bool &&
        data.pago is bool &&
        isOptionalString(data, 'fechaHora', 40) &&
        isOptionalString(data, 'registradoPor', 254);
    }

    function validAppConfig(data) {
      return data.keys().hasOnly(['añoActivo', 'umbralFidelidadAlerta']) &&
        data['añoActivo'] is int &&
        data['añoActivo'] >= 2000 &&
        data['añoActivo'] <= 2100 &&
        data.umbralFidelidadAlerta is number &&
        data.umbralFidelidadAlerta >= 0 &&
        data.umbralFidelidadAlerta <= 100;
    }

    match /usuarios/{uid} {
      allow read: if isSuperadmin() || (signedIn() && request.auth.uid == uid);
      allow create, update: if isSuperadmin() && validUsuario(request.resource.data);
      allow delete: if isSuperadmin();
    }

    match /grupos/{grupoId} {
      allow read: if hasProfile();
      allow create, update: if isSuperadmin() && validGrupo(request.resource.data);
      allow delete: if isSuperadmin();
    }

    match /ninos/{ninoId} {
      allow read: if isSuperadmin() || isAdminFor(resource.data.grupoId);
      allow create: if validNino(request.resource.data) &&
        (isSuperadmin() || isAdminFor(request.resource.data.grupoId));
      allow update: if validNino(request.resource.data) &&
        request.resource.data.grupoId == resource.data.grupoId &&
        (isSuperadmin() || isAdminFor(resource.data.grupoId));
      allow delete: if isSuperadmin() || isAdminFor(resource.data.grupoId);
    }

    match /sabados/{sabadoId} {
      allow read: if hasProfile();
      allow create, update: if isSuperadmin() && validSabado(request.resource.data);
      allow delete: if isSuperadmin();
    }

    match /registros/{registroId} {
      allow read: if canReadOrWriteNino(resource.data.ninoId);
      allow create: if validRegistro(request.resource.data) &&
        registroId == request.resource.data.sabadoId + '_' + request.resource.data.ninoId &&
        exists(/databases/$(database)/documents/sabados/$(request.resource.data.sabadoId)) &&
        canReadOrWriteNino(request.resource.data.ninoId);
      allow update: if validRegistro(request.resource.data) &&
        registroId == request.resource.data.sabadoId + '_' + request.resource.data.ninoId &&
        request.resource.data.sabadoId == resource.data.sabadoId &&
        request.resource.data.ninoId == resource.data.ninoId &&
        exists(/databases/$(database)/documents/sabados/$(request.resource.data.sabadoId)) &&
        canReadOrWriteNino(request.resource.data.ninoId);
      allow delete: if canReadOrWriteNino(resource.data.ninoId);
    }

    match /config/{configId} {
      allow read: if hasProfile();
      allow write: if isSuperadmin() && configId == 'app' && validAppConfig(request.resource.data);
    }

    match /historico/{year} {
      allow read, write: if isSuperadmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
